  "testScenarios": [
    {
      "name": "Database Cascade Failure",
      "description": "Database failure should cascade to all dependent services",
      "steps": [
        {
          "action": "inject_fault",
          "service": "database-service",
          "fault": {
            "type": "FAILURE",
            "isFailed": true
          }
        }
      ],
      "expectedResults": [
        {
          "service": "auth-service",
          "state": "failed"
        },
        {
          "service": "user-service",
          "state": "failed"
        },
        {
          "service": "product-service",
          "state": "failed"
        },
        {
          "service": "order-service",
          "state": "failed"
        },
        {
          "service": "api-gateway",
          "state": "degraded"
        }
      ]
    },
    {
      "name": "Latency Propagation Test",
      "description": "High latency should propagate based on thresholds",
      "steps": [
        {
          "action": "inject_fault",
          "service": "database-service",
          "fault": {
            "type": "LATENCY",
            "delay": 2000
          }
        }
      ],
      "expectedResults": [
        {
          "service": "auth-service",
          "state": "degraded"
        },
        {
          "service": "user-service",
          "state": "degraded"
        },
        {
          "service": "product-service",
          "state": "degraded"
        },
        {
          "service": "order-service",
          "state": "degraded"
        }
      ]
    },
    {
      "name": "Recovery Propagation Test",
      "description": "Service recovery should propagate to dependent services",
      "steps": [
        {
          "action": "inject_fault",
          "service": "database-service",
          "fault": {
            "type": "FAILURE",
            "isFailed": true
          }
        },
        {
          "action": "wait",
          "duration": 2000
        },
        {
          "action": "reset_service",
          "service": "database-service"
        }
      ],
      "expectedResults": [
        {
          "service": "auth-service",
          "state": "healthy"
        },
        {
          "service": "user-service",
          "state": "healthy"
        },
        {
          "service": "product-service",
          "state": "healthy"
        },
        {
          "service": "order-service",
          "state": "healthy"
        }
      ]
    },
    {
      "name": "Partial System Degradation",
      "description": "Single service failure should not affect entire system",
      "steps": [
        {
          "action": "inject_fault",
          "service": "product-service",
          "fault": {
            "type": "FAILURE",
            "isFailed": true
          }
        }
      ],
      "expectedResults": [
        {
          "service": "product-service",
          "state": "failed"
        },
        {
          "service": "order-service",
          "state": "degraded"
        },
        {
          "service": "api-gateway",
          "state": "degraded"
        },
        {
          "service": "auth-service",
          "state": "healthy"
        },
        {
          "service": "user-service",
          "state": "healthy"
        },
        {
          "service": "database-service",
          "state": "healthy"
        }
      ]
    },
    {
      "name": "Cascading Failure Recovery",
      "description": "Complex recovery scenario with multiple service dependencies",
      "steps": [
        {
          "action": "inject_fault",
          "service": "user-service",
          "fault": {
            "type": "FAILURE",
            "isFailed": true
          }
        },
        {
          "action": "wait",
          "duration": 1000
        },
        {
          "action": "inject_fault",
          "service": "product-service",
          "fault": {
            "type": "LATENCY",
            "delay": 3000
          }
        },
        {
          "action": "wait",
          "duration": 2000
        },
        {
          "action": "reset_service",
          "service": "user-service"
        }
      ],
      "expectedResults": [
        {
          "service": "user-service",
          "state": "healthy"
        },
        {
          "service": "order-service",
          "state": "degraded"
        },
        {
          "service": "product-service",
          "state": "healthy"
        }
      ]
    }
